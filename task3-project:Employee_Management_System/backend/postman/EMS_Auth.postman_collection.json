                    "auth",
                    "register"
                  ]
                }
              },
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [],
              "body": "{\n  \"success\": true,\n  \"message\": \"User registered successfully. Please login.\",\n  \"data\": {\n    \"user\": {\n      \"id\": \"uuid\",\n      \"role_id\": \"uuid\",\n      \"name\": \"Jane Employee\",\n      \"email\": \"jane@example.com\",\n      \"status\": \"active\"\n    }\n  },\n  \"meta\": {}\n}"
            }
          ]
        },
        {
          "name": "Login",
