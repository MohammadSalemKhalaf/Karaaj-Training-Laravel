            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Employee\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"StrongP@ssw0rd\",\n  \"password_confirmation\": \"StrongP@ssw0rd\"\n}"
            },
            "description": "Register a new user with default employee role. No token is returned; login is required to get a JWT token."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
